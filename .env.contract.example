# Contract test credentials — copy to .env.contract and fill in real values.
# DO NOT commit .env.contract — it contains live OAuth tokens.

# ── Google OAuth app ─────────────────────────────────────────────────────────
# Same client ID used by the app (can be the same GCP project, same credentials).
GOOGLE_OAUTH_CLIENT_ID=

# The client secret for the OAuth client (server-side only).
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Test Google account ───────────────────────────────────────────────────────
# A long-lived refresh token for a dedicated test Google account.
#
# How to obtain one:
#   1. Create a throwaway @gmail.com account (e.g. genesisway-contract-test@gmail.com).
#   2. Add a few calendar events in the next 7 days so pull tests see real data.
#   3. Use Google OAuth Playground (https://developers.google.com/oauthplayground)
#      with scope: https://www.googleapis.com/auth/calendar.readonly
#      → Step 1: Authorize APIs → Step 2: Exchange → copy refresh_token.
#   4. Paste it below.
GOOGLE_TEST_REFRESH_TOKEN=

# (Optional) A non-primary calendar ID in the test account to exercise
# multi-calendar fan-out. Leave blank to test primary only.
GOOGLE_TEST_EXTRA_CALENDAR_ID=

# ── ICS import ────────────────────────────────────────────────────────────────
# A stable public ICS URL used for the import contract test.
# Default (Google US Holidays — always public, never changes format):
GOOGLE_TEST_ICS_URL=https://calendar.google.com/calendar/ical/en.usa%23holiday%40group.v.calendar.google.com/public/basic.ics
